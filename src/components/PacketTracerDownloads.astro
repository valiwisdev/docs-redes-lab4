---
interface DownloadItem {
	title: string;
	href: string;
	description?: string;
}

interface Props {
	title?: string;
	description?: string;
	items: DownloadItem[];
}

const {
	title = 'Archivos de Packet Tracer',
	description = 'Descargue la topologia base o la version resuelta segun lo que necesite para el laboratorio.',
	items = [],
} = Astro.props;
---

<figure class="packet-tracer-downloads" aria-labelledby="packet-tracer-downloads-title">
	<div class="packet-tracer-downloads__header">
		<h3 id="packet-tracer-downloads-title">{title}</h3>
	</div>

	<p class="packet-tracer-downloads__help">
		{description}
	</p>

	<div class="packet-tracer-downloads__grid">
		{
			items.map((item) => (
				<article class="packet-tracer-downloads__card">
					<div class="packet-tracer-downloads__content">
						<strong>{item.title}</strong>
						{item.description && <p>{item.description}</p>}
					</div>

					<a class="packet-tracer-downloads__link" href={item.href} download>
						Descargar archivo
					</a>
				</article>
			))
		}
	</div>
</figure>

<style>
	.packet-tracer-downloads {
		margin: 1.5rem 0 2rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 1rem;
		overflow: hidden;
		background: var(--sl-color-bg-nav);
		box-shadow: 0 18px 40px color-mix(in srgb, var(--sl-color-black) 10%, transparent);
	}

	.packet-tracer-downloads__header {
		padding: 0.9rem 1rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
		background: color-mix(in srgb, var(--sl-color-text-accent) 8%, var(--sl-color-bg));
	}

	.packet-tracer-downloads__header h3 {
		margin: 0;
		font-size: 1rem;
	}

	.packet-tracer-downloads__help {
		margin: 0;
		padding: 0.85rem 1rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
		background: color-mix(in srgb, var(--sl-color-bg) 85%, var(--sl-color-text-accent) 15%);
		color: var(--sl-color-gray-2);
		font-size: 0.95rem;
	}

	.packet-tracer-downloads__grid {
		display: grid;
		padding: 1rem;
		gap: 1rem;
	}

	.packet-tracer-downloads__card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.85rem;
		background: color-mix(in srgb, var(--sl-color-bg) 70%, var(--sl-color-bg-nav));
	}

	.packet-tracer-downloads__content strong {
		display: block;
		font-size: 1rem;
	}

	.packet-tracer-downloads__content p {
		margin: 0.45rem 0 0;
		color: var(--sl-color-gray-2);
		font-size: 0.95rem;
	}

	.packet-tracer-downloads__link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 11.5rem;
		min-height: 2.5rem;
		padding: 0.5rem 0.85rem;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-4);
		background: color-mix(in srgb, var(--sl-color-white) 8%, transparent);
		color: inherit;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
	}

	.packet-tracer-downloads__link:hover {
		background: color-mix(in srgb, var(--sl-color-text-accent) 12%, var(--sl-color-bg));
	}

	.packet-tracer-downloads__link:focus-visible {
		outline: 3px solid var(--sl-color-text-accent);
		outline-offset: 2px;
	}

	@media (max-width: 50rem) {
		.packet-tracer-downloads__card {
			flex-direction: column;
			align-items: stretch;
		}

		.packet-tracer-downloads__link {
			width: 100%;
			min-width: 0;
		}
	}
</style>
