---
interface DownloadItem {
	title: string;
	href: string;
	description?: string;
}

interface Props {
	title?: string;
	description?: string;
	items: DownloadItem[];
}

const {
	title = 'Archivos de Packet Tracer',
	description = 'Descargue la topologia base o la version resuelta segun lo que necesite para el laboratorio.',
	items = [],
} = Astro.props;
---

<section class="packet-tracer-downloads" aria-labelledby="packet-tracer-downloads-title">
	<div class="packet-tracer-downloads__header">
		<h3 id="packet-tracer-downloads-title">{title}</h3>
		<p>{description}</p>
	</div>

	<div class="packet-tracer-downloads__grid">
		{
			items.map((item) => (
				<article class="packet-tracer-downloads__card">
					<div class="packet-tracer-downloads__content">
						<strong>{item.title}</strong>
						{item.description && <p>{item.description}</p>}
					</div>

					<a class="packet-tracer-downloads__link" href={item.href} download>
						Descargar archivo
					</a>
				</article>
			))
		}
	</div>
</section>

<style>
	.packet-tracer-downloads {
		margin: 1.75rem 0 2rem;
		padding: 1.25rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 1rem;
		background:
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--sl-color-text-accent) 10%, var(--sl-color-bg)) 0%,
				var(--sl-color-bg-nav) 100%
			);
		box-shadow: 0 18px 40px color-mix(in srgb, var(--sl-color-black) 9%, transparent);
	}

	.packet-tracer-downloads__header h3 {
		margin: 0;
		font-size: 1.15rem;
	}

	.packet-tracer-downloads__header p {
		margin: 0.55rem 0 0;
		color: var(--sl-color-gray-2);
	}

	.packet-tracer-downloads__grid {
		display: grid;
		gap: 1rem;
		margin-top: 1rem;
	}

	.packet-tracer-downloads__card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem;
		border: 1px solid color-mix(in srgb, var(--sl-color-text-accent) 18%, var(--sl-color-gray-5));
		border-radius: 0.9rem;
		background: color-mix(in srgb, var(--sl-color-white) 18%, transparent);
	}

	.packet-tracer-downloads__content strong {
		display: block;
		font-size: 1rem;
	}

	.packet-tracer-downloads__content p {
		margin: 0.45rem 0 0;
		color: var(--sl-color-gray-2);
		font-size: 0.95rem;
	}

	.packet-tracer-downloads__link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 12rem;
		min-height: 2.75rem;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--sl-color-text-accent) 28%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--sl-color-text-accent) 14%, var(--sl-color-bg));
		color: inherit;
		text-decoration: none;
		font-weight: 600;
	}

	.packet-tracer-downloads__link:hover {
		background: color-mix(in srgb, var(--sl-color-text-accent) 22%, var(--sl-color-bg));
	}

	.packet-tracer-downloads__link:focus-visible {
		outline: 3px solid var(--sl-color-text-accent);
		outline-offset: 2px;
	}

	@media (max-width: 50rem) {
		.packet-tracer-downloads__card {
			flex-direction: column;
			align-items: stretch;
		}

		.packet-tracer-downloads__link {
			width: 100%;
			min-width: 0;
		}
	}
</style>
