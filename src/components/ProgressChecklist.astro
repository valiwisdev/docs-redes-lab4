---
interface ChecklistItem {
	label: string;
	done?: boolean;
	html?: boolean;
}

interface Props {
	title?: string;
	description?: string;
	items: ChecklistItem[];
}

const {
	title = 'Checklist de avance',
	description = 'Resumen rápido de lo que ya está disponible en esta sección.',
	items = [],
} = Astro.props;

const componentId = `progress-checklist-${Math.random().toString(36).slice(2, 10)}`;
const storageKey = `progress-checklist:${title}:${items.map((item) => item.label).join('|')}`;
---

<section
	class="progress-checklist"
	aria-labelledby={`${componentId}-title`}
	data-progress-checklist
	data-storage-key={storageKey}
>
	<div class="progress-checklist__header">
		<h3 id={`${componentId}-title`}>{title}</h3>
		<p>{description}</p>
	</div>

	<ul class="progress-checklist__list">
		{items.map((item, index) => (
			<li
				class:list={['progress-checklist__item', item.done ? 'is-done' : 'is-pending']}
				data-checklist-item
				data-index={index}
			>
				<input
					class="progress-checklist__checkbox"
					type="checkbox"
					checked={item.done}
					aria-label={`Marcar item ${index + 1}`}
				/>
				{item.html ? (
					<span class="progress-checklist__label" set:html={item.label} />
				) : (
					<span class="progress-checklist__label">{item.label}</span>
				)}
				<span class="progress-checklist__status">{item.done ? 'Listo' : 'Pendiente'}</span>
			</li>
		))}
	</ul>
</section>

<script>
	const checklists = document.querySelectorAll('[data-progress-checklist]');

	for (const checklist of checklists) {
		const storageKey = checklist.getAttribute('data-storage-key') ?? '';
		const items = Array.from(checklist.querySelectorAll('[data-checklist-item]'));

		const applyState = (item, done) => {
			const checkbox = item.querySelector('input[type="checkbox"]');
			const status = item.querySelector('.progress-checklist__status');

			item.classList.toggle('is-done', done);
			item.classList.toggle('is-pending', !done);
			if (checkbox) checkbox.checked = done;
			if (status) status.textContent = done ? 'Listo' : 'Pendiente';
		};

		let saved = null;
		try {
			saved = JSON.parse(localStorage.getItem(storageKey) ?? 'null');
		} catch {
			saved = null;
		}

		items.forEach((item, index) => {
			const checkbox = item.querySelector('input[type="checkbox"]');
			if (!checkbox) return;

			if (Array.isArray(saved) && typeof saved[index] === 'boolean') {
				applyState(item, saved[index]);
			}

			checkbox.addEventListener('change', () => {
				applyState(item, checkbox.checked);
				const state = items.map((currentItem) => {
					const currentCheckbox = currentItem.querySelector('input[type="checkbox"]');
					return currentCheckbox?.checked ?? false;
				});
				localStorage.setItem(storageKey, JSON.stringify(state));
			});
		});
	}
</script>

<style>
	.progress-checklist {
		margin: 1.5rem 0 2rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 1rem;
		background:
			linear-gradient(
				145deg,
				color-mix(in srgb, var(--sl-color-text-accent) 12%, var(--sl-color-bg)) 0%,
				var(--sl-color-bg-nav) 100%
			);
		box-shadow: 0 18px 40px color-mix(in srgb, var(--sl-color-black) 10%, transparent);
		overflow: hidden;
	}

	.progress-checklist__header {
		padding: 1rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.progress-checklist__header h3 {
		margin: 0;
		font-size: 1rem;
	}

	.progress-checklist__header p {
		margin: 0.45rem 0 0;
		color: var(--sl-color-gray-2);
		font-size: 0.95rem;
	}

	.progress-checklist__list {
		list-style: none;
		margin: 0;
		padding: 1rem;
		display: grid;
		gap: 0.75rem;
	}

	.progress-checklist__item {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 0.8rem;
		padding: 0.9rem 1rem;
		border-radius: 0.85rem;
		border: 1px solid var(--sl-color-gray-5);
		background: color-mix(in srgb, var(--sl-color-bg) 78%, transparent);
	}

	.progress-checklist__checkbox {
		appearance: none;
		display: grid;
		place-items: center;
		width: 1.6rem;
		height: 1.6rem;
		border: 2px solid #c27c19;
		border-radius: 999px;
		background: color-mix(in srgb, #c27c19 12%, transparent);
		cursor: pointer;
	}

	.progress-checklist__checkbox::after {
		content: '';
		width: 0.45rem;
		height: 0.8rem;
		border: solid white;
		border-width: 0 2px 2px 0;
		transform: rotate(45deg) scale(0);
		transition: transform 120ms ease;
	}

	.progress-checklist__checkbox:checked {
		border-color: #1f9d55;
		background: #1f9d55;
	}

	.progress-checklist__checkbox:checked::after {
		transform: rotate(45deg) scale(1);
	}

	.progress-checklist__checkbox:focus-visible {
		outline: 3px solid var(--sl-color-text-accent);
		outline-offset: 2px;
	}

	.progress-checklist__label {
		font-size: 0.98rem;
	}

	.progress-checklist__status {
		padding: 0.28rem 0.7rem;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.progress-checklist__item.is-done .progress-checklist__status {
		background: color-mix(in srgb, #1f9d55 18%, transparent);
		color: #1f9d55;
	}

	.progress-checklist__item.is-pending .progress-checklist__status {
		background: color-mix(in srgb, #c27c19 18%, transparent);
		color: #c27c19;
	}

	@media (max-width: 40rem) {
		.progress-checklist__item {
			grid-template-columns: auto 1fr;
		}

		.progress-checklist__status {
			grid-column: 1 / -1;
			justify-self: start;
		}
	}
</style>
