---
import { Code } from '@astrojs/starlight/components';

interface PhysicalInterface {
	id: string;
	index: string;
}

interface PhysicalOption {
	label: string;
	value: string;
}

interface RouterBlock {
	title: string;
	template: string;
	physicalInterfaces: PhysicalInterface[];
}

interface Props {
	title?: string;
	blocks: RouterBlock[];
	physicalOptions?: PhysicalOption[];
	selectorHint?: string;
}

const {
	title = 'Comandos dinámicos',
	blocks,
	physicalOptions = [
		{ label: 'G0/x', value: 'G0/' },
		{ label: 'Fa0/x', value: 'Fa0/' },
		{ label: 'F0/x', value: 'F0/' },
		{ label: 'Gi0/x', value: 'Gi0/' },
		{ label: 'G0/0/x', value: 'G0/0/' },
		{ label: 'S0/0/x', value: 'S0/0/' },
	],
	selectorHint = 'La misma selección se aplica a R1, R2 y R3.',
} = Astro.props;

const componentId = `dynamic-cisco-${Math.random().toString(36).slice(2, 10)}`;

const renderTemplate = (template: string, physicalInterfaces: PhysicalInterface[], base: string) => {
	let result = template;
	for (const item of physicalInterfaces) {
		result = result.replaceAll(`{{${item.id}}}`, `${base}${item.index}`);
	}
	return result.trim();
};
---

<section class="dynamic-cisco" data-dynamic-cisco-global id={componentId}>
	<div class="dynamic-cisco__header">
		<div class="dynamic-cisco__title-group">
			<strong>{title}</strong>
			<span class="dynamic-cisco__badge">Selector global</span>
		</div>
	</div>

	<div class="dynamic-cisco__field">
		<div class="dynamic-cisco__field-copy">
			<div>
				<div class="dynamic-cisco__field-label">Interfaz base global</div>
				<div class="dynamic-cisco__hint">{selectorHint}</div>
			</div>
			<select data-role="physical-base">
				{physicalOptions.map((option, index) => (
					<option value={option.value} selected={index === 0}>{option.label}</option>
				))}
			</select>
		</div>
 	</div>

	<div class="dynamic-cisco__blocks">
		{blocks.map((block) => (
			<section
				class="dynamic-cisco__router"
				data-router-block
			>
				<h3>{block.title}</h3>

				{physicalOptions.map((option, index) => {
					const renderedCode = renderTemplate(block.template, block.physicalInterfaces, option.value);
					return (
						<div
							class="dynamic-cisco__code-variant"
							data-code-variant={option.value}
							hidden={index !== 0}
						>
							<Code code={renderedCode} lang="bash" />
						</div>
					);
				})}
			</section>
		))}
	</div>
</section>

<script>
	const globals = document.querySelectorAll('[data-dynamic-cisco-global]');

	for (const globalBlock of globals) {
		const baseSelect = globalBlock.querySelector('[data-role="physical-base"]');
		const routerBlocks = globalBlock.querySelectorAll('[data-router-block]');

		const render = () => {
			const base = baseSelect?.value ?? 'Fa0/';

			for (const routerBlock of routerBlocks) {
				const variants = routerBlock.querySelectorAll('[data-code-variant]');
				for (const variant of variants) {
					variant.hidden = variant.getAttribute('data-code-variant') !== base;
				}
			}
		};

		baseSelect?.addEventListener('change', render);
		render();
	}
</script>

<style>
	.dynamic-cisco {
		margin: 1.5rem 0 2rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 1rem;
		background: var(--sl-color-bg);
		overflow: hidden;
	}

	.dynamic-cisco__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		padding: 1rem 1rem 0.75rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-bg-nav);
	}

	.dynamic-cisco__title-group {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.dynamic-cisco__badge {
		padding: 0.25rem 0.7rem;
		border-radius: 999px;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--sl-color-gray-2);
	}

	.dynamic-cisco__field {
		padding: 1rem;
		margin: 1rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 1rem;
		background: var(--sl-color-bg-nav);
	}

	.dynamic-cisco__field-copy {
		display: grid;
		grid-template-columns: 1.2fr minmax(15rem, 22rem);
		gap: 1rem;
		align-items: center;
	}

	.dynamic-cisco__field-label {
		font-size: 0.95rem;
		font-weight: 600;
		margin-bottom: 0.25rem;
	}

	.dynamic-cisco__field select {
		width: 100%;
		min-height: 3rem;
		padding: 0.8rem 0.95rem;
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 0.9rem;
		background: var(--sl-color-bg);
		color: var(--sl-color-text);
		font-weight: 600;
	}

	.dynamic-cisco__hint {
		font-size: 0.9rem;
		color: var(--sl-color-gray-2);
		line-height: 1.45;
	}

	.dynamic-cisco__blocks {
		display: grid;
		gap: 1rem;
		padding: 0 1rem 1rem;
	}

	.dynamic-cisco__router {
		padding: 1rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 1rem;
		background: var(--sl-color-bg-nav);
	}

	.dynamic-cisco__router h3 {
		margin: 0 0 0.75rem;
		font-size: 1rem;
	}

	.dynamic-cisco__code-variant[hidden] {
		display: none;
	}

	@media (max-width: 50rem) {
		.dynamic-cisco__field-copy {
			grid-template-columns: 1fr;
		}
	}
</style>
